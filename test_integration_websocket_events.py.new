"""
Integration test for WebSocket event flow
Test: connect client → create submission → verify event type "TRIAGE_CREATED"
Test: update status → verify event type "TRIAGE_UPDATED"
Test: critical condition → verify event type "CRITICAL_ALERT"
"""
import pytest
import json
from django.test import TestCase, TransactionTestCase
from django.contrib.auth import get_user_model
from rest_framework.test import APIClient
from rest_framework import status
from triagesync_backend.apps.patients.models import PatientSubmission, Patient
from triagesync_backend.apps.realtime.services.broadcast_service import (
    broadcast_patient_created,
    broadcast_status_changed,
    broadcast_critical_alert
)
from triagesync_backend.apps.realtime.services.event_service import (
    build_patient_created_event,
    build_status_changed_event,
    build_critical_alert_event
)
from unittest.mock import patch, MagicMock, call

User = get_user_model()


class WebSocketEventFlowIntegrationTest(TransactionTestCase):
    """
    Integration test for WebSocket event flow and correct event names
    """
    
    def setUp(self):
        self.client = APIClient()
        
        # Create patient user and patient profile
        self.patient_user = User.objects.create_user(
            username="patientuser",
            email="patient@example.com",
            password="patientpass123",
            role="patient"
        )
        
        self.patient = Patient.objects.create(
            user=self.patient_user,
            name="Test Patient"
        )
        
        # Create staff user
        self.staff_user = User.objects.create_user(
            username="staffuser",
            email="staff@example.com",
            password="staffpass123",
            role="staff"
        )
    
    def test_triage_created_event_flow(self):
        """
        Test: create submission → verify event type "TRIAGE_CREATED"
        """
        # Login as patient
        self.client.force_authenticate(user=self.patient_user)
        
        # Mock WebSocket broadcast and event building
        with patch('triagesync_backend.apps.triage.views.broadcast_patient_created') as mock_broadcast:
            with patch('triagesync_backend.apps.triage.services.triage_service.evaluate_triage') as mock_triage:
                # Mock triage service response
                mock_triage.return_value = {
                    "data": {
                        "triage_result": {
                            "priority": 2,
                            "urgency_score": 75,
                            "condition": "Chest Pain",
                            "status": "waiting"
                        }
                    }
                }
                
                # Create triage submission
                response = self.client.post('/api/v1/triage/', {
                    "description": "Chest pain and shortness of breath"
                })
        
        # Verify submission success
        self.assertEqual(response.status_code, status.HTTP_201_CREATED)
        
        response_data = response.json()
        submission_id = response_data['id']
        
        # Verify WebSocket broadcast was called with correct parameters
        mock_broadcast.assert_called_once_with(submission_id, 2, 75)
        
        # Test the event building function directly
        event = build_patient_created_event(submission_id, 2, 75)
        
        # Verify event structure and correct event name
        self.assertIn('type', event)
        self.assertEqual(event['type'], "TRIAGE_CREATED")  # Correct event name per API contract
        
        # Verify event payload structure
        self.assertIn('data', event)
        event_data = event['data']
        self.assertEqual(event_data['submission_id'], submission_id)
        self.assertEqual(event_data['priority'], 2)
        self.assertEqual(event_data['urgency_score'], 75)
        
        # Verify timestamp is present
        self.assertIn('timestamp', event)
    
    def test_triage_updated_event_flow(self):
        """
        Test: update status → verify event type "TRIAGE_UPDATED"
        """
        # Create test submission
        submission = PatientSubmission.objects.create(
            patient=self.patient,
            symptoms="Test symptoms",
            priority=2,
            urgency_score=75,
            condition="Test Condition",
            status="waiting"
        )
        
        # Login as staff
        self.client.force_authenticate(user=self.staff_user)
        
        # Mock WebSocket broadcast
        with patch('triagesync_backend.apps.realtime.services.broadcast_service.broadcast_status_changed') as mock_broadcast:
            # Update patient status
            response = self.client.patch(
                f'/api/v1/dashboard/staff/patient/{submission.id}/status/',
                {"status": "in_progress"}
            )
        
        # Verify status update success
        self.assertEqual(response.status_code, status.HTTP_200_OK)
        
        # Verify WebSocket broadcast was called
        mock_broadcast.assert_called_once_with(submission.id, "in_progress")
        
        # Test the event building function directly
        event = build_status_changed_event(submission.id, "in_progress")
        
        # Verify event structure and correct event name
        self.assertIn('type', event)
        self.assertEqual(event['type'], "TRIAGE_UPDATED")  # Correct event name per API contract
        
        # Verify event payload structure
        self.assertIn('data', event)
        event_data = event['data']
        self.assertEqual(event_data['submission_id'], submission.id)
        self.assertEqual(event_data['new_status'], "in_progress")
        
        # Verify timestamp is present
        self.assertIn('timestamp', event)
    
    def test_critical_alert_event_flow(self):
        """
        Test: critical condition → verify event type "CRITICAL_ALERT"
        """
        # Create critical submission
        submission = PatientSubmission.objects.create(
            patient=self.patient,
            symptoms="Severe chest pain, difficulty breathing",
            priority=1,  # Critical priority
            urgency_score=95,
            condition="Acute Myocardial Infarction",
            status="waiting"
        )
        
        # Test critical alert broadcast directly
        with patch('triagesync_backend.apps.realtime.services.broadcast_service.broadcast_critical_alert') as mock_broadcast:
            # Trigger critical alert (this would normally be called by triage service)
            broadcast_critical_alert(submission.id)
        
        # Verify broadcast was called
        mock_broadcast.assert_called_once_with(submission.id)
        
        # Test the event building function directly
        event = build_critical_alert_event(submission.id)
        
        # Verify event structure and correct event name
        self.assertIn('type', event)
        self.assertEqual(event['type'], "CRITICAL_ALERT")  # Correct UPPERCASE event name
        
        # Verify event payload structure
        self.assertIn('data', event)
        event_data = event['data']
        self.assertEqual(event_data['submission_id'], submission.id)
        self.assertEqual(event_data['priority'], 1)  # Critical alerts always have priority 1
        self.assertIn('message', event_data)  # Should have a message field
        
        # Verify timestamp is present
        self.assertIn('timestamp', event)
    
    def test_all_event_names_uppercase(self):
        """
        Test that all event names are UPPERCASE per API contract
        """
        # Test TRIAGE_CREATED event
        event1 = build_patient_created_event(1, 2, 75)
        self.assertEqual(event1['type'], "TRIAGE_CREATED")
        self.assertTrue(event1['type'].isupper(), "TRIAGE_CREATED should be uppercase")
        
        # Test TRIAGE_UPDATED event
        event2 = build_status_changed_event(1, "in_progress")
        self.assertEqual(event2['type'], "TRIAGE_UPDATED")
        self.assertTrue(event2['type'].isupper(), "TRIAGE_UPDATED should be uppercase")
        
        # Test CRITICAL_ALERT event
        event3 = build_critical_alert_event(1)
        self.assertEqual(event3['type'], "CRITICAL_ALERT")
        self.assertTrue(event3['type'].isupper(), "CRITICAL_ALERT should be uppercase")
    
    def test_event_payload_structure_compliance(self):
        """
        Test that all events match API contract Section 3.6 payload structure
        """
        # Test TRIAGE_CREATED event payload
        event1 = build_patient_created_event(123, 1, 90)
        
        # Verify required fields
        self.assertIn('type', event1)
        self.assertIn('data', event1)
        self.assertIn('timestamp', event1)
        
        # Verify data structure
        data1 = event1['data']
        self.assertIn('submission_id', data1)
        self.assertIn('priority', data1)
        self.assertIn('urgency_score', data1)
        
        # Test TRIAGE_UPDATED event payload
        event2 = build_status_changed_event(456, "completed")
        
        # Verify required fields
        self.assertIn('type', event2)
        self.assertIn('data', event2)
        self.assertIn('timestamp', event2)
        
        # Verify data structure
        data2 = event2['data']
        self.assertIn('submission_id', data2)
        self.assertIn('new_status', data2)
        
        # Test CRITICAL_ALERT event payload
        event3 = build_critical_alert_event(789)
        
        # Verify required fields
        self.assertIn('type', event3)
        self.assertIn('data', event3)
        self.assertIn('timestamp', event3)
        
        # Verify data structure
        data3 = event3['data']
        self.assertIn('submission_id', data3)
        self.assertIn('priority', data3)
        self.assertEqual(data3['priority'], 1)  # Critical alerts always have priority 1
    
    def test_priority_update_event(self):
        """
        Test PRIORITY_UPDATE event (if implemented)
        """
        # Create test submission
        submission = PatientSubmission.objects.create(
            patient=self.patient,
            symptoms="Test symptoms",
            priority=3,
            urgency_score=50,
            condition="Test Condition",
            status="waiting"
        )
        
        # Login as staff
        self.client.force_authenticate(user=self.staff_user)
        
        # Update priority (assuming this endpoint exists)
        response = self.client.patch(
            f'/api/v1/dashboard/staff/patient/{submission.id}/priority/',
            {"priority": 1}
        )
        
        # If the endpoint exists, verify it works
        if response.status_code != status.HTTP_404_NOT_FOUND:
            self.assertEqual(response.status_code, status.HTTP_200_OK)
            
            # Verify database update
            submission.refresh_from_db()
            self.assertEqual(submission.priority, 1)
    
    def test_websocket_broadcast_integration_with_triage_service(self):
        """
        Test integration between triage service and WebSocket broadcasts
        """
        # Login as patient
        self.client.force_authenticate(user=self.patient_user)
        
        # Mock triage service to return critical condition
        with patch('triagesync_backend.apps.triage.services.triage_service.evaluate_triage') as mock_triage:
            with patch('triagesync_backend.apps.realtime.services.broadcast_service.broadcast_patient_created') as mock_patient_broadcast:
                with patch('triagesync_backend.apps.realtime.services.broadcast_service.broadcast_critical_alert') as mock_critical_broadcast:
                    
                    # Mock critical triage result
                    mock_triage.return_value = {
                        "data": {
                            "triage_result": {
                                "priority": 1,  # Critical
                                "urgency_score": 95,
                                "condition": "Acute Emergency",
                                "status": "waiting",
                                "is_critical": True
                            }
                        }
                    }
                    
                    # Create triage submission
                    response = self.client.post('/api/v1/triage/', {
                        "description": "Severe chest pain, can't breathe"
                    })
        
        # Verify submission success
        self.assertEqual(response.status_code, status.HTTP_201_CREATED)
        
        response_data = response.json()
        submission_id = response_data['id']
        
        # Verify patient created broadcast was called
        mock_patient_broadcast.assert_called_once_with(submission_id, 1, 95)
        
        # Note: Critical alert broadcast integration would depend on 
        # triage service implementation details


if __name__ == '__main__':
    pytest.main([__file__])
