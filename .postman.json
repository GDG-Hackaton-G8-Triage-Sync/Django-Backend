        {
          "name": "POST /api/v1/triage/ai/ - Critical Cardiac Case",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('priority_level');",
                  "    pm.expect(jsonData).to.have.property('urgency_score');",
                  "    pm.expect(jsonData).to.have.property('condition');",
                  "    pm.expect(jsonData).to.have.property('category');",
                  "    pm.expect(jsonData).to.have.property('is_critical');",
                  "    pm.expect(jsonData).to.have.property('explanation');",
                  "    pm.expect(jsonData).to.have.property('recommended_action');",
                  "    pm.expect(jsonData).to.have.property('reason');",
                  "    pm.expect(jsonData).to.have.property('source');",
                  "});",
                  "",
                  "pm.test(\"Priority level is valid (1-5)\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.priority_level).to.be.within(1, 5);",
                  "});",
                  "",
                  "pm.test(\"Urgency score is valid (0-100)\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.urgency_score).to.be.within(0, 100);",
                  "});",
                  "",
                  "pm.test(\"Category is valid enum\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var validCategories = ['Cardiac', 'Respiratory', 'Trauma', 'Neurological', 'General'];",
                  "    pm.expect(validCategories).to.include(jsonData.category);",
                  "});",
                  "",
                  "pm.test(\"is_critical is boolean\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(typeof jsonData.is_critical).to.equal('boolean');",
                  "});",
                  "",
                  "pm.test(\"Explanation is non-empty array\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.explanation).to.be.an('array').that.is.not.empty;",
                  "});",
                  "",
                  "pm.test(\"Critical cardiac case should have high priority\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.priority_level).to.be.within(1, 2);",
                  "    pm.expect(jsonData.urgency_score).to.be.above(80);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symptoms\": \"chest pain radiating to left arm, sweating\",\n  \"age\": 45,\n  \"gender\": \"male\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/triage/ai/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "triage", "ai", ""]
            },
            "description": "Test critical cardiac case with emergency symptoms"
          },
          "response": []
        },
