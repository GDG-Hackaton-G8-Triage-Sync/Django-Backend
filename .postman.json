        {
          "name": "POST /api/v1/auth/login/ - Patient Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has tokens\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('access');",
                  "    pm.expect(jsonData).to.have.property('refresh');",
                  "});",
                  "",
                  "// Save access token for subsequent requests",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('patient_access_token', jsonData.access);",
                  "pm.collectionVariables.set('patient_refresh_token', jsonData.refresh);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
